```{r}

# Rebalancing dates: first trading day of each month, training set only for K selection
# Full date range (train + test) used for monthly cluster assignments
rebal_dates_train <- train_df %>%
  filter(symbol == "SPY") %>%
  mutate(year_month = lubridate::floor_date(date, "month")) %>%
  group_by(year_month) %>%
  slice_min(date, n = 1) %>%
  ungroup() %>%
  pull(date)

rebal_dates_all <- algo_df %>%
  filter(symbol == "SPY") %>%
  mutate(year_month = lubridate::floor_date(date, "month")) %>%
  group_by(year_month) %>%
  slice_min(date, n = 1) %>%
  ungroup() %>%
  pull(date)

```

```{r}

# Helper: extract feature matrix for one rebalancing date
# Returns wide df with one row per ETF and four scaled features
# ETFs with any NA feature on that date are dropped
get_features_at <- function(date_val, data) {
  data %>%
    filter(symbol %in% sector_etfs, date == date_val) %>%
    select(symbol, pc2_filtered, rel_strength, beta, hit_rate) %>%
    drop_na()
}

```

```{r}

# Elbow method: fit K = 2 through 8 on training rebalancing dates
# For each K, fit k-means across all training dates and sum WCSS
# Recipe scales all four features before clustering

k_candidates <- 2:8

wcss_results <- map_dfr(k_candidates, function(k) {

  total_wcss <- map_dbl(rebal_dates_train, function(d) {

    feat <- get_features_at(d, algo_df)
    if (nrow(feat) < k + 1) return(NA_real_)

    rec <- recipe(~ pc2_filtered + rel_strength + beta + hit_rate, data = feat) %>%
      step_normalize(all_numeric_predictors())

    spec <- k_means(num_clusters = k)

    wf <- workflow() %>%
      add_recipe(rec) %>%
      add_model(spec) %>%
      fit(data = feat)

    # Extract WCSS (total within-cluster sum of squares)
    wf %>%
      extract_fit_engine() %>%
      pluck("tot.withinss")
  })

  tibble(K = k, wcss = sum(total_wcss, na.rm = TRUE))
})

```

```{r}

# Elbow chart: WCSS vs K
plot_ly(
  wcss_results,
  x    = ~K,
  y    = ~wcss,
  type = "scatter",
  mode = "lines+markers",
  line    = list(color = col_navy, width = 2),
  marker  = list(color = col_slate, size = 8)
) %>%
  layout(
    title  = list(text = "Elbow Method — K Selection", font = list(color = col_navy)),
    xaxis  = list(title = "Number of Clusters (K)", tickvals = k_candidates),
    yaxis  = list(title = "Total WCSS"),
    paper_bgcolor = "white",
    plot_bgcolor  = "#F5F7FA"
  )

```

```{r}


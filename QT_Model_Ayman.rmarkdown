plot_ly(
  spread_df,
  x    = ~spread * 100,
  type = "histogram",
  nbinsx = 30,
  marker = list(color = "#4C78A8", line = list(color = "white", width = 0.5))
) %>%
  add_segments(
    x     = spread_sd * 100, xend = spread_sd * 100,
    y     = 0,               yend = 20,
    line  = list(color = "#E45756", width = 2, dash = "dash"),
    name  = "1 SD",
    showlegend = FALSE
  ) %>%
  add_annotations(
    x         = spread_sd * 100,
    y         = 21,
    text      = paste0("SD = ", round(spread_sd * 100, 3), "%"),
    showarrow = FALSE,
    font      = list(color = "#E45756", size = 13)
  ) %>%
  layout(
    title  = list(text = "Distribution of Rank-1 vs Rank-2 Cluster Return Spread (Training)",
                  font = list(size = 15)),
    xaxis  = list(title = "Spread (%, daily return units)"),
    yaxis  = list(title = "Count"),
    bargap = 0.05
  )

```

# Section 7 — Signal Rules + Simulation

## Signal Logic

At each monthly rebalance date the strategy applies a three-step signal:

1.  **Cluster ranking.** Clusters are ranked by their equal-weighted average `rolling_avg_return` across constituent ETFs. The top cluster is the highest-ranked. This average can be negative — the rotation buffer and weighting rule handle that downstream.

2.  **Rotation buffer.** The strategy only rotates to a new top cluster if it outperforms the current cluster by more than `ROTATION_BUFFER` (2 standard deviations of the rank-1 vs rank-2 spread distribution observed over the training period, approximately 0.148%). A spread below this threshold is statistically indistinguishable from noise; one above it reflects a meaningfully strong momentum divergence.

3.  **ETF weighting within the top cluster.** ETFs are ranked by `rolling_avg_return`. Weight is assigned by inverse rank, normalised to sum to 1, across ETFs with strictly positive rolling average return. ETFs with non-positive returns receive zero weight. If all ETFs in the top cluster have non-positive returns the portfolio moves fully to cash for that period — a natural consequence of the weighting rule, documented here as an explicit assumption: *the strategy moves to cash when no ETF in the selected cluster shows positive momentum.*

```{r}

# compute_signal: derive ETF weight vector for one rebalancing date
# Inputs:
#   rebal_date     — the rebalancing date
#   prev_cluster   — cluster_id from previous rebalance (NULL on first rebalance)
#   cluster_assign — cluster_assignments df (date, symbol, cluster_id)
#   data           — algo_df containing rolling_avg_return
#   buffer         — rotation buffer threshold (default 0.5%)
# Returns: list(weights = tibble(symbol, weight), top_cluster_id = int)
# Example: compute_signal(as.Date("2025-01-02"), NULL, cluster_assignments, algo_df)
compute_signal <- function(rebal_date, prev_cluster, cluster_assign, data, buffer = 0.005) {

  # Current cluster membership and rolling returns for this date
  clusters_now <- cluster_assign %>%
    filter(date == rebal_date) %>%
    select(symbol, cluster_id)

  returns_now <- data %>%
    filter(date == rebal_date, symbol %in% sector_etfs) %>%
    select(symbol, rolling_avg_return)

  joined <- clusters_now %>%
    left_join(returns_now, by = "symbol") %>%
    drop_na(rolling_avg_return)

  # Rank clusters by equal-weighted average rolling return
  cluster_avgs <- joined %>%
    group_by(cluster_id) %>%
    summarise(cluster_avg = mean(rolling_avg_return, na.rm = TRUE), .groups = "drop") %>%
    arrange(desc(cluster_avg))

  new_top_id  <- cluster_avgs$cluster_id[1]
  new_top_avg <- cluster_avgs$cluster_avg[1]

  # Rotation buffer: stay with previous cluster unless new leader outperforms by > buffer
  if (!is.null(prev_cluster) && prev_cluster %in% cluster_avgs$cluster_id) {
    prev_avg <- cluster_avgs %>%
      filter(cluster_id == prev_cluster) %>%
      pull(cluster_avg)

    if (new_top_id != prev_cluster && (new_top_avg - prev_avg) <= buffer) {
      new_top_id <- prev_cluster
    }
  }

  # Rank ETFs within selected cluster; inverse-rank weight positive-return ETFs only
  top_etfs <- joined %>%
    filter(cluster_id == new_top_id) %>%
    arrange(desc(rolling_avg_return)) %>%
    filter(rolling_avg_return > 0) %>%
    mutate(
      rank     = row_number(),
      inv_rank = 1 / rank,
      weight   = inv_rank / sum(inv_rank)
    )

  # All sector ETFs get a weight entry; non-selected or non-positive return → 0
  weights_out <- tibble(symbol = sector_etfs) %>%
    left_join(top_etfs %>% select(symbol, weight), by = "symbol") %>%
    mutate(weight = replace_na(weight, 0))

  list(weights = weights_out, top_cluster_id = new_top_id)
}

```

## Simulation

```{r}

# Simulation loop: Jan 2025 – Mar 2026
# Rebalance days: gap return on old weights (co_return), intraday on new weights (oc_return)
# Non-rebalance days: cc_return on current weights

test_days <- algo_df %>%
  filter(symbol == "SPY",
         date >= as.Date("2025-01-01"),
         date <= as.Date("2026-03-31")) %>%
  arrange(date) %>%
  pull(date)

# Initialise state
pv           <- STARTING_CAPITAL
weights_now  <- tibble(symbol = sector_etfs, weight = 0)
prev_cluster <- NULL

portfolio_rows <- vector("list", length(test_days))
trade_rows     <- list()

for (i in seq_along(test_days)) {
  d <- test_days[i]

  # Today's returns and open price for sector ETFs
  ret_today <- algo_df %>%
    filter(date == d, symbol %in% sector_etfs) %>%
    select(symbol, cc_return, co_return, oc_return, open)

  if (d %in% rebal_dates_test) {

    # Step 1: mark old positions from T-1 close to T open (gap return)
    gap_r <- weights_now %>%
      left_join(ret_today %>% select(symbol, co_return), by = "symbol") %>%
      summarise(r = sum(weight * replace_na(co_return, 0))) %>%
      pull(r)
    pv_open <- pv * (1 + gap_r)

    # Step 2: compute signal
    sig          <- compute_signal(d, prev_cluster, cluster_assignments, algo_df, ROTATION_BUFFER)
    new_weights  <- sig$weights
    prev_cluster <- sig$top_cluster_id

    # Step 3: record trade log (quantities based on open price)
    trade_rows[[length(trade_rows) + 1]] <- new_weights %>%
      left_join(weights_now %>% rename(old_weight = weight), by = "symbol") %>%
      left_join(ret_today %>% select(symbol, open), by = "symbol") %>%
      mutate(
        old_value    = old_weight * pv_open,
        target_value = weight * pv_open,
        trade_value  = target_value - old_value,
        quantity     = if_else(!is.na(open) & open > 0, trade_value / open, 0),
        date         = d
      ) %>%
      select(date, symbol, weight, target_value, trade_value, quantity)

    # Step 4: intraday return on new weights (T open → T close)
    intra_r <- new_weights %>%
      left_join(ret_today %>% select(symbol, oc_return), by = "symbol") %>%
      summarise(r = sum(weight * replace_na(oc_return, 0))) %>%
      pull(r)
    pv_close <- pv_open * (1 + intra_r)

    weights_now <- new_weights

  } else {

    # Non-rebalance day: cc_return on current weights
    daily_r <- weights_now %>%
      left_join(ret_today %>% select(symbol, cc_return), by = "symbol") %>%
      summarise(r = sum(weight * replace_na(cc_return, 0))) %>%
      pull(r)
    pv_close <- pv * (1 + daily_r)
  }

  portfolio_rows[[i]] <- tibble(
    date            = d,
    portfolio_value = pv_close,
    daily_return    = pv_close / pv - 1
  )
  pv <- pv_close
}

portfolio_daily <- bind_rows(portfolio_rows)
trade_log       <- bind_rows(trade_rows)

```

## Equity Curve

```{r}

# SPY buy-and-hold benchmark: $1,000,000 deployed at start of test period
# cc_return used throughout for SPY (minor approximation vs strategy's oc_return on day 1)
spy_bh <- algo_df %>%
  filter(symbol == "SPY",
         date >= as.Date("2025-01-01"),
         date <= as.Date("2026-03-31")) %>%
  arrange(date) %>%
  select(date, cc_return) %>%
  mutate(spy_value = STARTING_CAPITAL * cumprod(1 + replace_na(cc_return, 0)))

# Combine for plotting
equity_df <- portfolio_daily %>%
  select(date, portfolio_value) %>%
  left_join(spy_bh %>% select(date, spy_value), by = "date")

plot_ly(equity_df, x = ~date) %>%
  add_lines(
    y    = ~portfolio_value,
    name = "Strategy",
    line = list(color = col_navy, width = 2)
  ) %>%
  add_lines(
    y    = ~spy_value,
    name = "SPY Buy & Hold",
    line = list(color = col_slate, width = 2, dash = "dash")
  ) %>%
  layout(
    title  = list(text = "Equity Curve — Strategy vs SPY (Jan 2025 – Mar 2026)",
                  font = list(color = col_navy)),
    xaxis  = list(title = "Date"),
    yaxis  = list(title = "Portfolio Value (USD)", tickformat = "$,.0f"),
    legend = list(orientation = "h", y = -0.15),
    paper_bgcolor = "white",
    plot_bgcolor  = "#F5F7FA"
  )

```

## Weight Allocation by Rebalance Date

```{r}

# Pivot trade_log to show ETF weights at each rebalance date
# Rows: rebalance date | Columns: ETF symbols | Values: weight (%)
n_rebal_rows <- nrow(trade_log %>% distinct(date))

trade_log %>%
  mutate(weight_pct = round(weight * 100, 1)) %>%
  select(date, symbol, weight_pct) %>%
  pivot_wider(names_from = symbol, values_from = weight_pct, values_fill = 0) %>%
  arrange(date) %>%
  gt() %>%
  tab_header(
    title    = "ETF Weight Allocation at Each Rebalance Date",
    subtitle = "Weights shown as % of portfolio; 0 = not held"
  ) %>%
  cols_label(date = "Rebalance Date") %>%
  fmt_number(columns = -date, decimals = 1) %>%
  tab_style(
    style     = list(cell_fill(color = col_navy), cell_text(color = "white", weight = "bold")),
    locations = cells_column_labels()
  ) %>%
  tab_style(
    style     = cell_text(color = col_navy, weight = "bold", size = "large"),
    locations = cells_title(groups = "title")
  ) %>%
  tab_style(
    style     = cell_text(color = col_slate, size = "small"),
    locations = cells_title(groups = "subtitle")
  ) %>%
  tab_options(
    table.border.top.color            = col_navy,
    table.border.bottom.color         = col_navy,
    column_labels.border.bottom.color = col_navy,
    table.font.size                   = 13,
    data_row.padding                  = px(5),
    container.height                  = px(380),
    container.overflow.y              = "auto"
  )

```


    style     = cell_text(color = col_navy, weight = "bold", size = "large"),
    locations = cells_title(groups = "title")
  ) %>%
  tab_style(
    style     = cell_text(color = col_slate, size = "small"),
    locations = cells_title(groups = "subtitle")
  ) %>%
  tab_options(
    table.border.top.color            = col_navy,
    table.border.bottom.color         = col_navy,
    column_labels.border.bottom.color = col_navy,
    table.font.size                   = 14,
    data_row.padding                  = px(6)
  )

```

```{r}

# 4a — Kalman Filter: smooth raw PC2 loadings per ETF independently
#
# 1D local level model: true loading evolves slowly, raw PC2 is noisy observation
# Locked: Q = 0.001 (process noise), R = 0.1 (observation noise)
#
# Returns long df: date, symbol, pc2_raw, pc2_filtered
# Example: apply_kalman_pc2(pc2_raw_df)
apply_kalman_pc2 <- function(pc2_df, Q = kalman_Q, R = kalman_R) {

  pc2_df %>%
    arrange(symbol, date) %>%
    group_by(symbol) %>%
    group_modify(function(df, key) {

      n    <- nrow(df)
      x    <- rep(NA_real_, n)
      p    <- rep(NA_real_, n)

      x[1] <- df$pc2_raw[1]
      p[1] <- R

      for (i in 2:n) {
        x_pred <- x[i - 1]
        p_pred <- p[i - 1] + Q
        k      <- p_pred / (p_pred + R)
        x[i]   <- x_pred + k * (df$pc2_raw[i] - x_pred)
        p[i]   <- (1 - k) * p_pred
      }

      df %>% mutate(pc2_filtered = x)
    }) %>%
    ungroup()
}

```

```{r}

# Apply Kalman filter and join both pc2 columns back onto algo_df
pc2_filtered_df <- apply_kalman_pc2(pc2_raw_df)

algo_df <- algo_df %>%
  left_join(
    pc2_filtered_df %>% select(date, symbol, pc2_raw, pc2_filtered),
    by = c("date", "symbol")
  ) %>%
  mutate(
    cluster_character = case_when(
      pc2_filtered >  0 ~ "cyclical",
      pc2_filtered <  0 ~ "defensive",
      TRUE              ~ NA_character_
    )
  )

```

```{r}

# 4b — Relative Strength vs SPY
# Rolling mean ETF return minus rolling mean SPY return over lookback_days
# slider::slide_dbl handles the rolling window cleanly in long format
spy_roll <- algo_df %>%
  filter(symbol == "SPY") %>%
  arrange(date) %>%
  mutate(spy_roll_mean = slider::slide_dbl(
    cc_return, mean, .before = lookback_days - 1, .complete = TRUE
  )) %>%
  select(date, spy_roll_mean)

algo_df <- algo_df %>%
  left_join(spy_roll, by = "date") %>%
  group_by(symbol) %>%
  arrange(date) %>%
  mutate(
    etf_roll_mean = slider::slide_dbl(
      cc_return, mean, .before = lookback_days - 1, .complete = TRUE
    ),
    rel_strength = etf_roll_mean - spy_roll_mean
  ) %>%
  ungroup() %>%
  select(-spy_roll_mean, -etf_roll_mean)

```

```{r}

# 4c — Beta to SPY
# Rolling OLS slope of ETF returns on SPY returns over lookback_days
spy_cc <- algo_df %>%
  filter(symbol == "SPY") %>%
  select(date, spy_cc = cc_return)

algo_df <- algo_df %>%
  left_join(spy_cc, by = "date") %>%
  group_by(symbol) %>%
  arrange(date) %>%
  mutate(
    beta = slider::slide2_dbl(
      cc_return, spy_cc,
      .f = function(y, x) {
        if (length(y) < lookback_days || any(is.na(c(y, x)))) return(NA_real_)
        coef(lm(y ~ x))[2]
      },
      .before   = lookback_days - 1,
      .complete = TRUE
    )
  ) %>%
  ungroup() %>%
  select(-spy_cc)

```

```{r}

# 4d — Momentum Consistency (Hit Rate)
# Proportion of positive cc_return days over lookback_days window
algo_df <- algo_df %>%
  group_by(symbol) %>%
  arrange(date) %>%
  mutate(
    hit_rate = slider::slide_dbl(
      cc_return,
      .f        = function(x) mean(x > 0, na.rm = FALSE),
      .before   = lookback_days - 1,
      .complete = TRUE
    )
  ) %>%
  ungroup()

```

```{r}

# End of Section 4 — pivot to wide model_df
# One row per date; each ETF's features as named columns ({feature}_{ETF})
# Only rows with at least one ETF having all four features retained
model_df <- algo_df %>%
  filter(symbol %in% sector_etfs) %>%
  select(date, symbol, pc2_filtered, cluster_character, rel_strength, beta, hit_rate) %>%
  pivot_wider(
    names_from  = symbol,
    values_from = c(pc2_filtered, cluster_character, rel_strength, beta, hit_rate)
  ) %>%
  arrange(date)

glimpse(model_df)


```

```{r}

# Dynamic monthly clustering: re-fit k-means at each rebalancing date (train + test)
# Returns one row per ETF per rebalancing date with cluster_id assigned
run_monthly_clustering <- function(rebal_dates, k, data) {

  map_dfr(rebal_dates, function(d) {

    feat <- get_features_at(d, data)
    if (nrow(feat) < k + 1) return(NULL)

    rec <- recipe(~ pc2_filtered + rel_strength + beta + hit_rate, data = feat) %>%
      step_normalize(all_numeric_predictors())

    spec <- k_means(num_clusters = k)

    wf <- workflow() %>%
      add_recipe(rec) %>%
      add_model(spec) %>%
      fit(data = feat)

    feat %>%
      mutate(
        cluster_id = as.integer(extract_cluster_assignment(wf)$.cluster),
        date       = d
      ) %>%
      select(date, symbol, cluster_id)
  })
}

cluster_assignments <- run_monthly_clustering(rebal_dates_all, K, algo_df)

```


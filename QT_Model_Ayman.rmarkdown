```{r, message = FALSE}

library(tidyverse)
library(tidyquant)

```

# Section 1 — Data

```{r}

# Pull daily OHLCV for all sector ETFs, SPY (benchmark), and XLG (performance tracker)
# Training: 2000-06-01 – 2024-12-31 | Test: 2025-01-01 – 2026-03-31
# Note: XLC (2018), XLG (2005), XLRE (2015) have shorter histories — handled via dynamic universe
df <- tidyquant::tq_get(
  c("SPY", "XLB", "XLC", "XLE", "XLF", "XLG", "XLI", "XLK", "XLP", "XLRE", "XLV", "XLU", "XLY"),
  get  = "stock.prices",
  from = "2000-06-01",
  to   = "2026-03-31"
)

```

## Return Computation

```{r}

# Yahoo Finance only provides adjusted close, not adjusted open.
# Derive adjusted open using the daily adjustment ratio: adj_open = open * (adjusted / close)
# This applies the same split/dividend scaling to open prices for consistency.
#
# Return conventions (all log returns — additive across time, standard for PCA and analysis):
#   cc_return: close-to-close (primary return for all analysis, PCA, and feature computation)
#   oo_return: open-to-open (adjusted)
#   co_return: overnight gap — today's adj open vs yesterday's adj close
#   oc_return: intraday — today's adj close vs today's adj open
df <- df %>%
  group_by(symbol) %>%
  arrange(date) %>%
  mutate(
    adj_open  = open * (adjusted / close),
    cc_return = log(adjusted / lag(adjusted)),
    oo_return = log(adj_open  / lag(adj_open)),
    co_return = log(adj_open  / lag(adjusted)),
    oc_return = log(adjusted  / adj_open)
  ) %>%
  ungroup()

```

## Data Summary

```{r}

library(gt)

# Compute all diagnostic stats in one place
date_coverage <- df %>%
  group_by(date) %>%
  summarise(n_symbols = n_distinct(symbol), .groups = "drop")

n_universe      <- n_distinct(df$symbol)
n_dates_partial <- sum(date_coverage$n_symbols < n_universe)
n_nulls         <- sum(is.na(df %>% select(open, high, low, close, adjusted)))
n_bad_prices    <- df %>% filter(open <= 0 | high <= 0 | low <= 0 | close <= 0 | adjusted <= 0) %>% nrow()

return_quantiles <- df %>%
  filter(!is.na(cc_return)) %>%
  select(symbol, cc_return, oo_return, co_return, oc_return) %>%
  pivot_longer(-symbol, names_to = "Convention", values_to = "return") %>%
  group_by(Convention) %>%
  summarise(
    Min    = round(min(return,            na.rm = TRUE), 4),
    `1%`   = round(quantile(return, 0.01, na.rm = TRUE), 4),
    Median = round(median(return,         na.rm = TRUE), 4),
    `99%`  = round(quantile(return, 0.99, na.rm = TRUE), 4),
    Max    = round(max(return,            na.rm = TRUE), 4),
    .groups = "drop"
  )

# Key-value summary card
tibble(
  Check  = c(
    "Date range",
    "Symbols",
    "Total rows",
    "NAs in price columns",
    "Rows with zero or negative prices",
    "Dates with full universe (13 symbols)",
    "Dates with partial universe"
  ),
  Result = c(
    paste(format(min(df$date), "%b %Y"), "–", format(max(df$date), "%b %Y")),
    paste(sort(unique(df$symbol)), collapse = ", "),
    format(nrow(df), big.mark = ","),
    as.character(n_nulls),
    as.character(n_bad_prices),
    format(sum(date_coverage$n_symbols == n_universe), big.mark = ","),
    format(n_dates_partial, big.mark = ",")
  )
) %>%
  gt() %>%
  cols_label(Check = "", Result = "") %>%
  tab_style(
    style     = list(cell_text(weight = "bold", color = "#1B2A4A")),
    locations = cells_body(columns = Check)
  ) %>%
  tab_style(
    style     = cell_fill(color = "#F5F7FA"),
    locations = cells_body(rows = c(1, 3, 5, 7))
  ) %>%
  tab_options(
    column_labels.hidden        = TRUE,
    table.border.top.color      = "#1B2A4A",
    table.border.bottom.color   = "#1B2A4A",
    table.font.size             = 14,
    data_row.padding            = px(6)
  )

```


# Section 4 — Feature Engineering

```{r}

# Locked parameters
lookback_days <- 63L
kalman_Q      <- 0.001
kalman_R      <- 0.1

# Tradeable sector ETFs — SPY and XLG excluded from all feature computation
sector_etfs <- c("XLB", "XLC", "XLE", "XLF", "XLI", "XLK", "XLP", "XLRE", "XLV", "XLU", "XLY")

```

```{r}

# 4a — Rolling PCA: compute PC2 loading per ETF per day over lookback_days window
#
# At each date t:
#   1. Pivot trailing lookback_days rows to wide (date x ETF return matrix)
#   2. Drop ETFs with any NA in the window (handles XLC/XLRE before full history)
#   3. Compute covariance matrix → eigen decomposition → extract PC2 loadings
#   4. Sign-align: force XLK loading positive, flip all if needed
#
# Returns long df: date, symbol, pc2_raw
# Example: compute_rolling_pc2(algo_df, 63L)
compute_rolling_pc2 <- function(data, lookback) {

  etf_data <- data %>%
    filter(symbol %in% sector_etfs) %>%
    select(date, symbol, cc_return) %>%
    arrange(date, symbol)

  dates <- sort(unique(etf_data$date))
  n     <- length(dates)
  results <- vector("list", n)

  for (i in seq_along(dates)) {

    if (i < lookback) next

    window_dates <- dates[(i - lookback + 1):i]

    wide <- etf_data %>%
      filter(date %in% window_dates) %>%
      pivot_wider(names_from = symbol, values_from = cc_return)

    # Drop ETFs with any NA in window (short history)
    ret_mat <- wide %>%
      select(-date) %>%
      select(where(~ !any(is.na(.))))

    if (ncol(ret_mat) < 3) next

    cov_mat <- cov(ret_mat)
    eig     <- eigen(cov_mat)

    # PC2 = second eigenvector; sign-align so XLK loads positively
    pc2 <- eig$vectors[, 2]
    names(pc2) <- colnames(ret_mat)
    if ("XLK" %in% names(pc2) && pc2["XLK"] < 0) pc2 <- -pc2

    results[[i]] <- tibble(
      date    = dates[i],
      symbol  = names(pc2),
      pc2_raw = as.numeric(pc2)
    )
  }

  bind_rows(results)
}

```

```{r}
#| cache: true

# Run rolling PCA on full algo_df (train + test) — takes a moment
# Cached: result saved to disk after first render, skipped on subsequent renders
pc2_raw_df <- compute_rolling_pc2(algo_df, lookback_days)

```

